# Copy this file to `.env` and fill in real values.
# Anything already set in the OS environment takes precedence over .env.

# ─── Required ───────────────────────────────────────────────────

# HMAC secret for session cookies. 32+ chars random.
# Generate with:  openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-long-random-hex-string-32-chars-min

# ─── Optional ───────────────────────────────────────────────────

# HTTP port (default 8081)
# PORT=8081

# Bind address. Default 127.0.0.1 — assumes Cloudflare Tunnel /
# reverse proxy. Set to 0.0.0.0 to listen on all interfaces.
# BIND_ADDR=127.0.0.1

# Public-facing origin used in QR codes / invite URLs.
# Leave blank to use the browser's location.origin.
# PUBLIC_ORIGIN=https://chat.acidblob.com

# Database backend: sqlite (default) | mysql
# DB_TYPE=sqlite
# SQLITE_PATH=emoji_chat.db
# MYSQL_DSN=root:@tcp(127.0.0.1:3306)/emoji_chat?charset=utf8mb4&parseTime=true&loc=UTC
